{
  "name": "vscode-plantuml-json-yaml-gen",
  "displayName": "PlantUML JSON/YAML Generators",
  "description": "Registers JSON and YAML source-to-PlantUML generators into PlantUML Core Generator.",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "extensionDependencies": [
    "local.vscode-plantuml-core-gen"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "vscode-plantuml-gen-api": "file:../vscode-plantuml-gen-api"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.4"
  }
}
