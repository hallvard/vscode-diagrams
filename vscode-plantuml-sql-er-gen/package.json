{
  "name": "vscode-plantuml-sql-er-gen",
  "displayName": "PlantUML SQL ER Generator",
  "description": "Registers a SQL CREATE TABLE to PlantUML ER generator into PlantUML Core Generator.",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "extensionDependencies": [
    "local.vscode-plantuml-core-gen"
  ],
  "activationEvents": [
    "onExtension:local.vscode-plantuml-core-gen",
    "onCommand:vscodePlantumlCoreGen.openAsVirtualPlantUml"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "vscode-plantuml-gen-api": "file:../vscode-plantuml-gen-api"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.4"
  }
}
