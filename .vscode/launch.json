  "version": "0.2.0",
  "configurations": [
    {
      "request": "launch",
      "type": "extensionHost",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/vscode-plantuml-core-gen",
        "--extensionDevelopmentPath=${workspaceFolder}/vscode-plantuml-json-yaml-gen"
      ],
      "name": "Launch Extension",
      "outFiles": [
        "${workspaceFolder}/vscode-plantuml-core-gen/out/**/*.js",
        "${workspaceFolder}/vscode-plantuml-json-yaml-gen/out/**/*.js"
      ]
    }

  ]
}
